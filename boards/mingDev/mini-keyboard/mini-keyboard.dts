/dts-v1/;
#include <nordic/nrf52840_qiaa.dtsi>
#include <zephyr/dt-bindings/gpio/gpio.h>
#include <zephyr/dt-bindings/i2c/i2c.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <zephyr/dt-bindings/input/keymap.h>
#include <zephyr/dt-bindings/led/led.h>
#include <zephyr/dt-bindings/mipi_dbi/mipi_dbi.h>
#include <zephyr/dt-bindings/pwm/pwm.h>
#include "mini-keyboard-pinctrl.dtsi"

/ {
	model = "pro";
	compatible = "mingdev,mini-keyboard";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
		zephyr,led-strip = &rgb_strip;
		zephyr,display = &st7789v;
	};

	aliases {
		led-strip = &rgb_strip;
		pwm-led0 = &screen_backlight;
	};

	kbd_matrix: kbd-matrix {
		compatible = "gpio-kbd-matrix";
		status = "okay";

		row-gpios = <&gpio0 15 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>,
			    <&gpio0 7  (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>,
			    <&gpio0 12 (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>,
			    <&gpio0 4  (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>,
			    <&gpio1 9  (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>,
			    <&gpio0 8  (GPIO_PULL_DOWN | GPIO_ACTIVE_HIGH)>;

		col-gpios = <&gpio0 5 GPIO_ACTIVE_HIGH>,
			    <&gpio0 6 GPIO_ACTIVE_HIGH>,
			    <&gpio0 26 GPIO_ACTIVE_HIGH>,
			    <&gpio0 30 GPIO_ACTIVE_HIGH>;

		actual-key-mask = <0x3e 0x3e 0x1e 0x2b>;
		no-ghostkey-check;

		keymap {
			compatible = "input-keymap";
			keymap = <
				MATRIX_KEY(0, 3, INPUT_KEY_MUTE)

				MATRIX_KEY(1, 0, INPUT_KEY_NUMLOCK)
				MATRIX_KEY(1, 1, INPUT_KEY_KPSLASH)
				MATRIX_KEY(1, 2, INPUT_KEY_KPASTERISK)
				MATRIX_KEY(1, 3, INPUT_KEY_KPMINUS)

				MATRIX_KEY(2, 0, INPUT_KEY_KP7)
				MATRIX_KEY(2, 1, INPUT_KEY_KP8)
				MATRIX_KEY(2, 2, INPUT_KEY_KP9)

				MATRIX_KEY(3, 0, INPUT_KEY_KP4)
				MATRIX_KEY(3, 1, INPUT_KEY_KP5)
				MATRIX_KEY(3, 2, INPUT_KEY_KP6)
				MATRIX_KEY(3, 3, INPUT_KEY_KPPLUS)

				MATRIX_KEY(4, 0, INPUT_KEY_KP1)
				MATRIX_KEY(4, 1, INPUT_KEY_KP2)
				MATRIX_KEY(4, 2, INPUT_KEY_KP3)

				MATRIX_KEY(5, 0, INPUT_KEY_KP0)
				MATRIX_KEY(5, 1, INPUT_KEY_KPDOT)
				MATRIX_KEY(5, 3, INPUT_KEY_KPENTER)
			>;
			row-size = <6>;
			col-size = <4>;
		};
	};

	hid_dev_0: hid_dev_0 {
		compatible = "zephyr,hid-device";
		label = "HID0";
		protocol-code = "keyboard";
		in-report-size = <9>;
		in-polling-period-us = <1000>;
	};

	ec11_encoder: ec11-encoder {
		compatible = "gpio-qdec";
		status = "okay";
		gpios = <&gpio0 10 (GPIO_PULL_UP | GPIO_ACTIVE_HIGH)>,
			<&gpio1 6 (GPIO_PULL_UP | GPIO_ACTIVE_HIGH)>;
		steps-per-period = <2>;
		zephyr,axis = <INPUT_REL_WHEEL>;
		sample-time-us = <2000>;
		idle-poll-time-us = <2000>;
		idle-timeout-ms = <200>;
	};

	zephyr,user {
		wakeup-gpios = <&gpio0 22 GPIO_ACTIVE_LOW>;
		battery-enable-gpios = <&gpio0 9 GPIO_ACTIVE_HIGH>;
		rgb-power-enable-gpios = <&gpio0 13 GPIO_ACTIVE_HIGH>;
	};

	pwmleds {
		compatible = "pwm-leds";

		screen_backlight: screen-backlight {
			pwms = <&pwm0 0 PWM_MSEC(10) PWM_POLARITY_INVERTED>;
			label = "Screen Backlight";
		};
	};

	mipi_dbi {
		compatible = "zephyr,mipi-dbi-spi";
		spi-dev = <&spi3>;
		dc-gpios = <&gpio0 3 GPIO_ACTIVE_HIGH>;
		reset-gpios = <&gpio1 10 GPIO_ACTIVE_LOW>;
		write-only;
		#address-cells = <1>;
		#size-cells = <0>;

		st7789v: st7789v@0 {
			compatible = "sitronix,st7789v";
			reg = <0>;
			mipi-max-frequency = <32000000>;
			width = <320>;
			height = <172>;
			x-offset = <0>;
			y-offset = <34>;
			ready-time-ms = <120>;
			vcom = <0x19>;
			gctrl = <0x35>;
			vrhs = <0x12>;
			vdvs = <0x20>;
			mdac = <0x60>;
			gamma = <0x01>;
			colmod = <0x05>;
			lcm = <0x2c>;
			porch-param = [0c 0c 00 33 33];
			cmd2en-param = [5a 69 02 01];
			pwctrl1-param = [a4 a1];
			pvgam-param = [D0 04 0D 11 13 2B 3F 54 4C 18 0D 0B 1F 23];
			nvgam-param = [D0 04 0C 11 13 2C 3F 44 51 2F 1F 1F 20 23];
			ram-param = [00 F0];
			rgb-param = [CD 08 14];
			mipi-mode = "MIPI_DBI_MODE_SPI_4WIRE";
		};
	};
};

&adc {
	status = "okay";
};

&i2c1 {
	compatible = "nordic,nrf-twim";
	status = "okay";
	pinctrl-0 = <&i2c1_default>;
	pinctrl-1 = <&i2c1_sleep>;
	pinctrl-names = "default", "sleep";
	clock-frequency = <I2C_BITRATE_STANDARD>;

	ip5306: ip5306@75 {
		compatible = "i2c-device";
		reg = <0x75>;
	};
};

&spi2 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	pinctrl-0 = <&spi2_default>;
	pinctrl-1 = <&spi2_sleep>;
	pinctrl-names = "default", "sleep";

	rgb_strip: ws2812@0 {
		compatible = "worldsemi,ws2812-spi";
		reg = <0>;
		spi-max-frequency = <4000000>;
		chain-length = <17>;
		color-mapping = <LED_COLOR_ID_GREEN
				 LED_COLOR_ID_RED
				 LED_COLOR_ID_BLUE>;
		spi-one-frame = <0x70>;
		spi-zero-frame = <0x40>;
		bits-per-symbol = <8>;
	};
};

&spi3 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	cs-gpios = <&gpio0 2 GPIO_ACTIVE_LOW>;
	pinctrl-0 = <&spi3_default>;
	pinctrl-1 = <&spi3_sleep>;
	pinctrl-names = "default", "sleep";
};

&pwm0 {
	status = "okay";
	pinctrl-0 = <&pwm0_default>;
	pinctrl-1 = <&pwm0_sleep>;
	pinctrl-names = "default", "sleep";
};

&uicr {
	nfct-pins-as-gpios;
	gpio-as-nreset;
};

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&gpiote {
	status = "okay";
};

zephyr_udc0: &usbd {
	compatible = "nordic,nrf-usbd";
	status = "okay";

	cdc_acm_uart0: cdc_acm_uart0 {
		compatible = "zephyr,cdc-acm-uart";
		label = "PRO Config CDC ACM";
	};
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 DT_SIZE_K(48)>;
		};

		slot0_partition: partition@c000 {
			label = "image-0";
			reg = <0x0000c000 DT_SIZE_K(472)>;
		};

		slot1_partition: partition@82000 {
			label = "image-1";
			reg = <0x00082000 DT_SIZE_K(472)>;
		};

		storage_partition: partition@f8000 {
			label = "storage";
			reg = <0x000f8000 DT_SIZE_K(32)>;
		};
	};
};
