{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "nRF: Configure environment",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/ncs-env.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "nRF: Build CAF Demo",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/build.ps1"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "nRF: Pristine Build CAF Demo",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/build.ps1",
                "-Pristine"
            ],
            "problemMatcher": []
        }
    ]
}
